{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ccusage-menubar",
  "version": "0.5.0",
  "identifier": "com.ccusage-menubar.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "/",
        "width": 280,
        "height": 580,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0OTRDRjU5ODczRTcyOUYKUldTZmNqNkhXYytVNUJhZ3NEbmZSZi9hZGhtTTJOdnBtNEdlVmkzRmwrQVNsTXhwMGdvNFU0ajIK",
      "endpoints": [
        "https://github.com/crudo/ccusage-menubar/releases/latest/download/latest.json"
      ]
    }
  }
}
